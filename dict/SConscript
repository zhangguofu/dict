# -*- coding: utf-8 -*-
"""
SConscript for dict core library
"""

Import('env')

# 获取当前目录和项目根目录
cwd = Dir('.')
root = cwd.Dir('..')

# 设置构建目录（.o 文件输出到 build/obj/dict/）
build_obj_dir = root.Dir('build/obj/dict')
VariantDir(build_obj_dir, cwd, duplicate=0)

# 核心源文件（使用 build_obj_dir 中的路径）
src = [
    build_obj_dir.File('src/dict_hash.c'),
    build_obj_dir.File('src/dict_core.c'),
]

# 克隆环境以添加包含路径
lib_env = env.Clone()
lib_env.Append(CPPPATH = [cwd.Dir('inc')])

# 创建库（输出到 build/lib）
lib = lib_env.Library(root.File('build/lib/dict'), src)

# 获取库文件的父目录作为 lib_path
lib_path = root.Dir('build/lib')

# 返回库和库路径
Return('lib', 'lib_path')
